{
  "id": "receipt_v1",
  "name": "Simple Receipt",
  "docType": "receipt",
  "page": {
    "size": "A4",
    "margin": 40
  },
  "styles": {
    "font": "Helvetica",
    "fontSize": 10.5,
    "color": "#111827"
  },
  "blocks": [
    {
      "type": "logo",
      "id": "logo",
      "position": { "x": 525, "y": 790 },
      "width": 28,
      "height": 28,
      "content": {
        "dataUrl": "{{business.logoDataUrl}}"
      }
    },
    {
      "type": "header",
      "id": "header",
      "position": { "x": 40, "y": 790 },
      "content": {
        "title": "RECEIPT",
        "businessName": "{{business.name}}",
        "invoiceId": "Receipt #: {{invoice.id}}",
        "date": "Date: {{invoice.date}}"
      }
    },
    {
      "type": "customer",
      "id": "customer",
      "position": { "x": 40, "y": 710 },
      "width": 515,
      "height": 58,
      "padding": 10,
      "content": {
        "title": "Received From",
        "name": "{{customer.name}}",
        "phone": "{{customer.phone}}",
        "email": "{{customer.email}}"
      }
    },
    {
      "type": "table",
      "id": "items",
      "position": { "x": 40, "y": 620 },
      "rowHeight": 28,
      "columns": [
        { "key": "name", "label": "Item", "width": 180, "align": "left" },
        { "key": "qty", "label": "Amount", "width": 120, "align": "right" },
        { "key": "price", "label": "Rate/Fee", "width": 115, "align": "right" },
        { "key": "total", "label": "Total", "width": 100, "align": "right" }
      ],
      "data": "{{items}}"
    },
    {
      "type": "summary",
      "id": "summary",
      "position": { "x": 355, "y": 220 },
      "content": {
        "subtotal": "{{summary.subtotalFormatted}}",
        "discount": "{{summary.discountFormatted}}",
        "tax": "{{summary.taxFormatted}}",
        "total": "{{summary.totalFormatted}}"
      }
    }
  ]
}
